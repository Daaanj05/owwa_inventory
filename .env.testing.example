APP_ENV=testing
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true

# NEVER point tests at MySQL — RefreshDatabase runs migrate:fresh and wipes Capstone_DB.
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

BROADCAST_CONNECTION=null
CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array
