# UAT mail worker profile — queue:work on laptop, website stays on Render.
# Copy to .env.uat-worker (gitignored), fill secrets, then: .\switch-env.ps1 uat-worker
# See docs/UAT_EMAIL_HYBRID.md

APP_NAME="OWWA Inventory"
APP_ENV=local
# Must match Render APP_KEY exactly (copy from Render dashboard)
APP_KEY=base64:YOUR_RENDER_APP_KEY
APP_DEBUG=false
# Render public URL — verification links in emails must point here
APP_URL=https://owwa-inventory.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# Neon PostgreSQL — parse from Neon connection string (pooling OFF, SSL on)
# postgresql://USERNAME:PASSWORD@HOST/DATABASE?sslmode=require
DB_CONNECTION=pgsql
DB_HOST=ep-xxxx.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_DATABASE=owwa4a-database
DB_USERNAME=neondb_owner
DB_PASSWORD=
DB_SSLMODE=require

SESSION_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file

# Gmail SMTP — worker sends queued welcome/verification emails from laptop
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM_ADDRESS=you@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# Not used by queue:work for mail; kept for Laravel boot consistency
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=deepseek-r1:7b
